pipeline {
  agent any

  environment {
    DOCKERHUB_USER  = credentials('dockerhub-username')
    DOCKERHUB_PASS  = credentials('dockerhub-password')
    IMAGE_TAG       = "${GIT_COMMIT[0..7]}"
    KUBECONFIG      = '/var/lib/jenkins/.kube/config'
  }

  options {
    buildDiscarder(logRotator(numToKeepStr: '10'))
    timeout(time: 30, unit: 'MINUTES')
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
        echo "Building commit: ${IMAGE_TAG} on branch: ${GIT_BRANCH}"
      }
    }

    stage('DockerHub Login') {
      steps {
        sh 'echo "$DOCKERHUB_PASS" | docker login -u "$DOCKERHUB_USER" --password-stdin'
      }
    }

    stage('Build Docker Images') {
      parallel {
        stage('Build Backend') {
          steps {
            dir('foodapp/backend') {
              sh "docker build -t ${DOCKERHUB_USER}/foodapp-backend:${IMAGE_TAG} -t ${DOCKERHUB_USER}/foodapp-backend:latest ."
            }
          }
        }
        stage('Build Frontend') {
          steps {
            dir('foodapp/frontend') {
              sh "docker build -t ${DOCKERHUB_USER}/foodapp-frontend:${IMAGE_TAG} -t ${DOCKERHUB_USER}/foodapp-frontend:latest ."
            }
          }
        }
      }
    }

    stage('Push to DockerHub') {
      steps {
        sh """
          docker push ${DOCKERHUB_USER}/foodapp-backend:${IMAGE_TAG}
          docker push ${DOCKERHUB_USER}/foodapp-backend:latest
          docker push ${DOCKERHUB_USER}/foodapp-frontend:${IMAGE_TAG}
          docker push ${DOCKERHUB_USER}/foodapp-frontend:latest
        """
      }
    }

    stage('Deploy to Kubernetes') {
      steps {
        sh """
          kubectl apply -f foodapp/k8s/base/storage.yaml
          kubectl apply -f foodapp/k8s/base/service.yaml
          sed -i 's|DOCKERHUB_USER|${DOCKERHUB_USER}|g' foodapp/k8s/base/deployment.yaml
          sed -i 's|IMAGE_TAG|${IMAGE_TAG}|g'            foodapp/k8s/base/deployment.yaml
          kubectl apply -f foodapp/k8s/base/deployment.yaml
          kubectl apply -f foodapp/k8s/base/hpa.yaml
          kubectl rollout status statefulset/mongodb --timeout=180s
          kubectl rollout status deployment/backend  --timeout=120s
          kubectl rollout status deployment/frontend --timeout=120s
        """
      }
    }

    stage('Smoke Test') {
      steps {
        sh '''
          WORKER_IP=$(kubectl get nodes -o jsonpath="{.items[1].status.addresses[0].address}")
          echo "Testing http://${WORKER_IP}:30001"
          curl -f --retry 5 --retry-delay 5 http://${WORKER_IP}:30001 || exit 1
          echo "Smoke test passed"
        '''
      }
    }

  }

  post {
    success {
      echo "Deployment ${IMAGE_TAG} succeeded"
    }
    failure {
      // node block required to run sh in post
      node('') {
        sh '''
          kubectl rollout undo deployment/backend  || true
          kubectl rollout undo deployment/frontend || true
        '''
      }
    }
    always {
      // node block required to run sh in post
      node('') {
        sh """
          docker rmi ${DOCKERHUB_USER}/foodapp-backend:${IMAGE_TAG}  || true
          docker rmi ${DOCKERHUB_USER}/foodapp-frontend:${IMAGE_TAG} || true
        """
      }
    }
  }
}
